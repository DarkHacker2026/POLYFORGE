# Copy this to .env or set it directly in your shell.
# Do not commit real keys.
FIREWORKS_API_KEY=fw_replace_me

# Override if Fireworks exposes different model ids in your account.
CANDIDATE_MODEL=accounts/fireworks/models/kimi-k2p6
RULE_MODEL=accounts/fireworks/models/gemma-4-26b-a4b

# Lite model for fast, cheap IR extraction (Task 1).
# Uses a much smaller model — we don't need massive reasoning resources
# just for extracting structural JSON from a kernel.
PARSER_MODEL=accounts/fireworks/models/gemma-2-9b-it